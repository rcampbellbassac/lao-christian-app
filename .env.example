# Base path used by Vite for assets/router base.
# Project-site GH Pages example: /lao-christian-app/
# Custom domain / root hosting example: /
VITE_BASE_PATH=/

# Optional content origin override for non-absolute URLs in index.json.
# Keep empty to use URLs directly from src/assets/data/index.json.
# Example: https://laoadventist-media.s3.us-west-2.amazonaws.com/
VITE_CONTENT_BASE_URL=

# Optional remote index URL for dynamic content metadata/version checks.
# Example: https://laoadventist-media.s3.us-west-2.amazonaws.com/index.json
VITE_REMOTE_INDEX_URL=

# Prefer gzip content URLs when `url_gzip` exists in the index.
# Set to false to always use `url`.
VITE_PREFER_GZIP=true
