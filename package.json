{
  "name": "laochristian",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^22.0.0 || ^24.0.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build:pages": "run-p type-check \"build-only {@}\" --",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "normalize:data": "node scripts/normalize-content.mjs",
    "normalize:data:check": "node scripts/normalize-content.mjs && node -e \"const fs=require('fs');const p='src/assets/data-normalized/normalization-report.json';console.log(fs.readFileSync(p,'utf8'))\"",
    "content:release": "node scripts/build-content-release.mjs",
    "content:publish": "bash scripts/publish-content.sh",
    "pages:build:project": "VITE_BASE_PATH='/lao-christian-app/' npm run build-only",
    "pages:build:root": "VITE_BASE_PATH='/' npm run build-only",
    "docker:up": "docker compose up -d --build",
    "docker:dev": "docker compose --profile dev up -d --build app-dev"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/vue-fontawesome": "^3.0.8",
    "@tailwindcss/vite": "^4.3.2",
    "html-to-image": "^1.11.13",
    "localforage": "^1.10.0",
    "pinia": "^3.0.1",
    "tailwindcss": "^4.1.7",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.1",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.14",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/eslint-plugin": "^1.1.38",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "~10.0.0",
    "jiti": "^2.4.2",
    "jsdom": "^26.0.0",
    "minimatch": "^9.0.7",
    "npm-run-all2": "^7.0.2",
    "prettier": "3.5.3",
    "typescript": "~5.8.0",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.2.8"
  },
  "overrides": {
    "js-beautify": {
      "editorconfig": "^3.0.2"
    }
  }
}
